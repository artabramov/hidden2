# Logging severity threshold for the application.
# Values: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Log message format used by the Python logging system.
# Defines which fields appear in each log line.
LOG_FORMAT="%(asctime)s %(levelname)s %(name)s %(message)s"

# Path to the global maintenance lock file.
# When this file exists, the API rejects requests with HTTP 503.
MAINTENANCE_LOCK_PATH=/var/lib/hidden/.lock

# Directory containing runtime secret keys.
# Used to locate gocryptfs and restic passphrase files.
SECRETS_DIR=/media/secrets

# Directory containing encrypted data (ciphertext).
# Safe to back up or move. Without the passphrase it is unreadable.
GOCRYPTFS_CIPHERDIR=/var/lib/hidden/encrypted

# Directory where the decrypted filesystem is mounted.
# The application reads and writes data here.
GOCRYPTFS_MOUNTPOINT=/var/lib/hidden/decrypted

# Length of the randomly generated gocryptfs passphrase.
# Used only on the first start if no passphrase file exists.
GOCRYPTFS_PASSPHRASE_LENGTH=80

# Interval (seconds) for checking the mount state of gocryptfs.
# The check is based on the presence of the passphrase file.
GOCRYPTFS_WATCHDOG_INTERVAL_SECONDS=5

# Enables or disables automatic restic backups.
# When enabled, periodic snapshots of encrypted data are created.
RESTIC_ENABLED=true

# Location of the restic repository storing backup snapshots.
# May be a local path or any restic-supported backend.
RESTIC_REPOSITORY=/media/backups

# Cron schedule defining when restic backups run.
# Uses standard cron syntax evaluated inside the container.
RESTIC_CRON_SCHEDULE="0 3 * * *"

# Retention policy applied to prune old restic snapshots.
# Passed directly to the "restic forget" command.
RESTIC_FORGET_ARGS="--keep-daily 7 --keep-weekly 4 --keep-monthly 6"

# SQLite journaling mode used by the database engine.
# WAL improves concurrency for typical web workloads.
SQLITE_JOURNAL_MODE=WAL

# SQLite synchronization level controlling write durability.
# NORMAL balances performance and protection from data loss.
SQLITE_SYNCHRONOUS=NORMAL

# Maximum time in milliseconds SQLite waits on database locks.
# Helps avoid transient "database is locked" errors.
SQLITE_BUSY_TIMEOUT=10000

# Location used for SQLite temporary tables and indices.
# MEMORY stores temporary data in RAM for better performance.
SQLITE_TEMP_STORE=MEMORY

# Network address where the Uvicorn HTTP server binds.
# 0.0.0.0 allows connections from any interface.
UVICORN_HOST=0.0.0.0

# TCP port where the Uvicorn HTTP server listens.
# Incoming HTTP requests to the application use this port.
UVICORN_PORT=80
